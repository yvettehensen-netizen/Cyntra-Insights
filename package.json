    "test:adversarial-input-batch": "node scripts/test/run_adversarial_input_batch_regression.mjs",
    "test:adversarial-input-batch:generate": "node scripts/test/run_input_batch_scorecards.mjs --manifest scripts/test/fixtures/adversarial_input_batch_cases.json --output-dir reports/test-suite/adversarial-input-batch-scorecards",
    "test:e2e-sector-fixtures": "node scripts/test/run_end_to_end_sector_fixture_regression.mjs",
    "test:dashboard-pipeline": "node scripts/test/run_dashboard_pipeline_smoke.mjs",
    "test:auth-routes": "node scripts/test/run_auth_route_consolidation.mjs",
    "test:analysis-routes": "node scripts/test/run_analysis_route_consolidation.mjs",
    "test:portal-resilience": "node scripts/test/run_portal_resilience_regression.mjs",
    "predeploy:boardroom": "npm run -s test:boardroom-golden && npm run -s test:board-guard-regression && npm run -s test:strategic-pipeline-guardrails"
