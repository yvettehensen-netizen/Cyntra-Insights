    "test:flywheel-slot-lock-v4": "node scripts/test/run_flywheel_slot_lock_v4_regression.mjs",
    "test:saas-platform": "node scripts/test/run_saas_platform_regression.mjs",
    "test:ggz-quality": "node scripts/test/run_ggz_quality_regression.mjs",
    "test:autonomous-discovery": "node scripts/test/run_autonomous_discovery_regression.mjs",
    "test:platform-api": "node scripts/test/run_platform_api_regression.mjs",
    "test:platform-session-persistence": "node scripts/test/run_platform_session_persistence_regression.mjs",
    "test:board-report-quality": "node scripts/test/run_board_report_quality_regression.mjs",
    "test:report-quality": "node scripts/test/run_report_quality_regression.mjs",
    "test:report-pdf-actions": "node scripts/test/run_report_pdf_actions_regression.mjs",
    "test:report-download-runtime": "node scripts/test/run_report_download_runtime_regression.mjs",
    "test:scenario-distinctness": "node scripts/test/run_scenario_distinctness_regression.mjs",
    "test:metadata-consistency": "node scripts/test/run_metadata_consistency_regression.mjs",
    "test:intervention-engine": "node scripts/test/run_intervention_engine_smoke_test.mjs",
    "test:analysis-map": "node scripts/test/run_analysis_map_regression.mjs",
    "test:multi-sector-golden": "node scripts/test/run_multi_sector_golden_regression.mjs",
    "test:board-memo-quality": "node scripts/test/run_board_memo_quality_regression.mjs",
    "test:memory-outcomes": "node scripts/test/run_memory_outcome_regression.mjs",
    "test:sector-recommendation-ranking": "node scripts/test/run_sector_recommendation_ranking_regression.mjs",
    "test:input-batch-scorecards": "node scripts/test/run_input_batch_scorecards_regression.mjs",
