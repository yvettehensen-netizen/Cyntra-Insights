    "test:strategic-agent-shape": "node scripts/test/run_strategic_agent_shape_regression.mjs",
    "test:cyntra-stability": "rm -rf /tmp/cyntra-stability-regression && npx tsc scripts/test/cyntra_stability_regression.ts --module nodenext --target es2020 --skipLibCheck --types node --rootDir scripts/test --outDir /tmp/cyntra-stability-regression && node /tmp/cyntra-stability-regression/cyntra_stability_regression.js",
    "test:cyntra-pipeline": "node scripts/test/cyntra_pipeline_regression.ts",
