{
  "name": "cyntra-insights",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node src/server/server.js",
    "preview": "vite preview",
    "check": "node scripts/checkProjectSetup.mjs",
    "ingest:precedents": "node scripts/precedent-ingest.mjs",
    "smoke:decision-infra": "node scripts/smoke-decision-infra.mjs",
    "sql:ops-bootstrap": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/sql/00_ops_observability_views.sql",
    "sql:assert:level2": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/sql/10_level2_health_assertions.sql",
    "check:level2-invariants": "bash scripts/check-level2-invariants.sh",
    "stress:baseline": "bash scripts/run-stress-baseline.sh",
    "stress:spike": "bash scripts/run-spike.sh",
    "stress:burst": "bash scripts/run-burst.sh",
    "stress:soak-24h": "bash scripts/run-soak-24h.sh",
    "health:sql": "bash scripts/run-sql-health.sh",
    "health:thresholds": "node scripts/check-thresholds.mjs",
    "report:level2": "node scripts/generate-level2-summary.mjs",
    "nightly:level2": "bash scripts/run-nightly-level2.sh",
    "weekly:level2": "bash scripts/run-weekly-level2.sh",
    "predeploy:invariants": "bash scripts/predeploy/check-invariants.sh",
    "predeploy:validate": "bash scripts/predeploy/run-predeploy-validation.sh",
    "predeploy:smoke": "bash scripts/predeploy/run-local-smoke-validation.sh",
    "predeploy:sql": "bash scripts/predeploy/run-sql-health-assertions.sh",
    "predeploy:summary": "node scripts/predeploy/generate-predeploy-summary.mjs",
    "predeploy:contract": "node scripts/predeploy/validate-contract.mjs",
    "predeploy:phase-a": "bash scripts/predeploy/run-phase-a-checklist.sh",
    "predeploy:e2e": "bash scripts/predeploy/run-phase-a-e2e.sh",
    "predeploy:e2e:enterprise100": "bash scripts/predeploy/run-phase-a-e2e.sh --with-enterprise-suite",
    "predeploy:alert": "node scripts/predeploy/alert-predeploy-breach.mjs",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test -c tests/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test -c tests/e2e/playwright.config.ts --debug",
    "test:seed-analyses": "node scripts/test/seed_analyses.mjs --count 100",
    "test:run-100-analyses": "node scripts/test/run_100_analyses.mjs --count 100",
    "test:intelligence-suite": "node scripts/test/run_intelligence_test_suite.mjs",
    "test": "node scripts/test/run_unit_smoke.mjs",
    "anchor:scan": "node scripts/reporting/anchor-scan.mjs",
    "report:compare": "node scripts/reporting/report-compare.mjs",
    "ci:enforce-fail-conditions": "node scripts/ci/enforce_intelligence_fail_conditions.mjs",
    "ci:nightly-summary": "node scripts/ci/generate_nightly_summary.mjs",
    "intelligence:extract-patterns": "node scripts/intelligence/extract_patterns.mjs",
    "intelligence:forecast": "node scripts/intelligence/forecast_decision_outcomes.mjs",
    "intelligence:drift": "node scripts/intelligence/detect_drift.mjs",
    "intelligence:risk": "node scripts/intelligence/calc_risk_evolution.mjs",
    "intelligence:governance": "node scripts/intelligence/autonomous_governance.mjs",
    "intelligence:board-summary": "node scripts/intelligence/generate_board_summary.mjs",
    "intelligence:cycle": "node scripts/intelligence/run_intelligence_cycle.mjs",
    "intelligence:pipeline": "bash scripts/intelligence/run-intelligence-pipeline.sh",
    "predeploy:phase-a:intelligence": "npm run -s predeploy:phase-a && npm run -s intelligence:pipeline"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.1",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/postgrest-js": "^2.93.1",
    "@supabase/realtime-js": "^2.93.1",
    "@supabase/supabase-js": "^2.93.1",
    "baseline-browser-mapping": "^2.9.11",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.344.0",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "object-assign": "^4.1.1",
    "openai": "^4.20.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.3.0",
    "resend": "^6.7.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@eslint/js": "^9.9.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@playwright/test": "^1.50.1",
    "autoprefixer": "^10.4.23",
    "cssesc": "^3.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "gensync": "^1.0.0-beta.2",
    "globals": "^15.9.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  }
}
