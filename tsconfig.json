{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "types": ["vite/client"]
  },

  "include": [
    "src/aurelius/narrative/**/*",
    "src/aurelius/executive/**/*",
    "src/aurelius/sector/**/*",
    "src/aurelius/hooks/useCyntraAnalysis.tsx",
    "src/api/sector/**/*",
    "src/vite-env.d.ts"
  ],

  "exclude": [
    "supabase/functions",
    "src/academy",
    "src/analytics",
    "src/pages/old_analyses",
    "src/cyntra",
    "src/pages/ProcessAnalysisPage.tsx",
    "node_modules"
  ]
}
